# Environment Variables for Portfolio Site
# Copy this file as .env.local and update the values

# JWT Secret for authentication (must be at least 32 characters)
# Generate a secure random string for production
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-characters

# Admin Password Hash
# Default password: "password"
# Generate new hash with: node -e "console.log(require('bcryptjs').hashSync('your-new-password', 10))"
ADMIN_PASSWORD_HASH=$2a$10$92IXUNpkjO0rOQ5byMi.Ye4oKoEa3Ro9llC/.og/at2.uheWG/igi

# Note: For Vercel deployment, set these in:
# Project Settings > Environment Variables
# Or use: vercel env add JWT_SECRET
#         vercel env add ADMIN_PASSWORD_HASH
